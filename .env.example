# Amore Movies — environment.
# Copy this file to `.env.local` and fill in a key to turn on real AI.
# WITHOUT a key, the app still works — "Similar movies" and the assistant fall
# back to the built-in local recommendation engine.

# --- Free AI (recommended: Google Gemini) ----------------------------------
# Get a free key at https://aistudio.google.com/apikey  (very generous free tier)
GEMINI_API_KEY=
# Default model is gemini-2.5-flash (2.0-flash had 0 free quota on our project).
# GEMINI_MODEL=gemini-2.5-flash

# --- Supabase (Phase 3 backend — optional until you go live) ----------------
# Create a free project at https://supabase.com → Project Settings → API.
# Without these the app runs fully on the local mock store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (never NEXT_PUBLIC). For admin/ingestion scripts.
SUPABASE_SERVICE_ROLE_KEY=

# --- TMDB (real movie data + posters — Phase 3) -----------------------------
# Free key at https://www.themoviedb.org/settings/api  (v4 read token recommended)
TMDB_API_KEY=
TMDB_READ_TOKEN=
